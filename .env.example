# ---- Supabase ----
# Project URL and anon key are safe for client-side (Streamlit) use.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service-role key is SERVER-SIDE ONLY. Used by scripts/run_refresh.py and
# other backend jobs to write data under RLS bypass. NEVER load this in
# Streamlit page code or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Market data provider ----
# "dhan" for the live DhanHQ v2 API, "mock" for the offline/dev provider.
MARKET_DATA_PROVIDER=mock

# DhanHQ v2 credentials (https://dhanhq.co/docs/v2/). Only required when
# MARKET_DATA_PROVIDER=dhan.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ---- Fundamentals provider ----
# Dhan does not expose PE / PEG / dividend data. "manual" reads curated
# seed/CSV records from Supabase; "mock" generates synthetic data for dev.
FUNDAMENTALS_PROVIDER=mock

# ---- Screener thresholds (defaults; overridable per-user in Settings) ----
DEFAULT_DIVIDEND_YIELD_THRESHOLD=3.0
DEFAULT_PEG_THRESHOLD=1.0
DEFAULT_STALE_DATA_THRESHOLD_MINUTES=30

# ---- Scheduling ----
# Only used by the standalone APScheduler process (scripts/run_refresh.py
# --daemon). GitHub Actions cron does not need this.
INTRADAY_REFRESH_INTERVAL_MINUTES=15

# ---- Misc ----
APP_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
